# Supabase — get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (Netlify Functions) — never use VITE_ prefix for these
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# GitHub Personal Access Token with read:project and repo scopes
# Create at: https://github.com/settings/tokens
GITHUB_PAT=ghp_your-token-here
